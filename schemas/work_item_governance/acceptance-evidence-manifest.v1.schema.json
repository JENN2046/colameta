{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colameta.local/schemas/work-item-governance/acceptance-evidence-manifest.v1.schema.json",
  "title": "ColaMeta Acceptance Evidence Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "acceptance_manifest_id", "work_item_id", "task_version",
    "gate_event_id", "accepted_state_version", "artifact_ids", "artifact_manifest",
    "artifact_manifest_digest", "decision_ids", "principal_context", "created_at"
  ],
  "properties": {
    "schema_version": {"const": "acceptance_evidence_manifest.v1"},
    "acceptance_manifest_id": {"$ref": "definitions.v1.schema.json#/$defs/acceptanceManifestId"},
    "work_item_id": {"$ref": "definitions.v1.schema.json#/$defs/workItemId"},
    "task_version": {"$ref": "definitions.v1.schema.json#/$defs/taskVersion"},
    "gate_event_id": {"$ref": "definitions.v1.schema.json#/$defs/gateEventId"},
    "accepted_state_version": {"type": "integer", "minimum": 1},
    "artifact_ids": {
      "type": "array", "minItems": 1, "maxItems": 1024, "uniqueItems": true,
      "items": {"$ref": "definitions.v1.schema.json#/$defs/artifactId"}
    },
    "artifact_manifest": {
      "type": "array", "minItems": 1, "maxItems": 1024,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "kind", "uri", "immutable_ref", "digest"],
        "properties": {
          "artifact_id": {"$ref": "definitions.v1.schema.json#/$defs/artifactId"},
          "kind": {"enum": ["report", "validation", "git_commit", "git_diff", "file", "test_report", "evidence_receipt", "other"]},
          "uri": {"type": "string", "minLength": 1, "maxLength": 8192},
          "immutable_ref": {"type": "string", "minLength": 1, "maxLength": 8192},
          "digest": {"$ref": "definitions.v1.schema.json#/$defs/sha256"}
        }
      }
    },
    "artifact_manifest_digest": {"$ref": "definitions.v1.schema.json#/$defs/sha256"},
    "decision_ids": {
      "type": "array", "minItems": 1, "maxItems": 1024, "uniqueItems": true,
      "items": {"$ref": "definitions.v1.schema.json#/$defs/decisionId"}
    },
    "principal_context": {"$ref": "definitions.v1.schema.json#/$defs/principalContext"},
    "created_at": {"$ref": "definitions.v1.schema.json#/$defs/timestamp"}
  }
}
