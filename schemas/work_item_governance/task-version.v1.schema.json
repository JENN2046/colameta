{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colameta.local/schemas/work-item-governance/task-version.v1.schema.json",
  "title": "ColaMeta Task Version v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "work_item_id", "task_version", "objective_ref", "plan_version_refs",
    "artifact_contract", "approval_requirements", "reporting_destination",
    "expected_receipt_contract", "payload_digest", "created_at"
  ],
  "properties": {
    "schema_version": {"const": "task_version.v1"},
    "work_item_id": {"$ref": "definitions.v1.schema.json#/$defs/workItemId"},
    "task_version": {"$ref": "definitions.v1.schema.json#/$defs/taskVersion"},
    "objective_ref": {"type": ["string", "null"], "maxLength": 8192},
    "plan_version_refs": {
      "type": "array", "maxItems": 1024, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 2048}
    },
    "artifact_contract": {"$ref": "definitions.v1.schema.json#/$defs/metadata"},
    "approval_requirements": {"$ref": "definitions.v1.schema.json#/$defs/metadata"},
    "reporting_destination": {"$ref": "definitions.v1.schema.json#/$defs/metadata"},
    "expected_receipt_contract": {"$ref": "definitions.v1.schema.json#/$defs/metadata"},
    "payload": {"$ref": "definitions.v1.schema.json#/$defs/metadata"},
    "payload_digest": {"$ref": "definitions.v1.schema.json#/$defs/sha256"},
    "created_at": {"$ref": "definitions.v1.schema.json#/$defs/timestamp"}
  }
}
