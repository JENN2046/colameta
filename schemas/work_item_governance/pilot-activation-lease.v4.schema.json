{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colameta.local/schemas/wig-p3-bounded-single-project-pilot-activation-lease.v4.schema.json",
  "title": "Bounded Single-Project Pilot Activation Lease v4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "lease_id", "authorization_id", "authorization_digest", "scope_envelope_digest", "spec_manifest_digest", "storage_schema_contract_digest", "fact_reconciliation_contract_digest", "semantic_rules_digest", "tool_allowlist_digest", "write_matrix_digest", "execution_attempt_slot_schema_sha256", "execution_authorization_receipt_schema_sha256", "authentication_conformance_receipt_schema_sha256", "expiry_conformance_receipt_schema_sha256", "source_binding", "runtime_binding", "principal_binding", "scope_binding", "window", "quotas", "usage", "policy", "maintenance", "failure_behavior", "status", "state_version", "created_at", "updated_at"],
  "properties": {
    "schema_version": {"const": "wig_p3_bounded_single_project_pilot_activation_lease.v4"},
    "lease_id": {"$ref": "#/$defs/lease_id"},
    "authorization_id": {"type": "string", "pattern": "^WIG-P3-AUTHORITATIVE-SINGLE-PROJECT-PILOT-[A-Z0-9-]+$", "maxLength": 192},
    "authorization_digest": {"$ref": "#/$defs/sha256"},
    "scope_envelope_digest": {"$ref": "#/$defs/sha256"},
    "spec_manifest_digest": {"$ref": "#/$defs/sha256"},
    "storage_schema_contract_digest": {"$ref": "#/$defs/sha256"},
    "fact_reconciliation_contract_digest": {"$ref": "#/$defs/sha256"},
    "semantic_rules_digest": {"$ref": "#/$defs/sha256"},
    "tool_allowlist_digest": {"$ref": "#/$defs/sha256"},
    "write_matrix_digest": {"$ref": "#/$defs/sha256"},
    "execution_attempt_slot_schema_sha256": {"$ref": "#/$defs/sha256"},
    "execution_authorization_receipt_schema_sha256": {"$ref": "#/$defs/sha256"},
    "authentication_conformance_receipt_schema_sha256": {"$ref": "#/$defs/sha256"},
    "expiry_conformance_receipt_schema_sha256": {"$ref": "#/$defs/sha256"},
    "source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation_commit", "implementation_tree", "wheel_sha256", "installed_inventory_sha256", "durable_artifact_evidence_digest", "durable_checkout_path_digest", "durable_wheel_path_digest"],
      "properties": {
        "implementation_commit": {"$ref": "#/$defs/git_sha1"},
        "implementation_tree": {"$ref": "#/$defs/git_sha1"},
        "wheel_sha256": {"$ref": "#/$defs/sha256"},
        "installed_inventory_sha256": {"$ref": "#/$defs/sha256"},
        "durable_artifact_evidence_digest": {"$ref": "#/$defs/sha256"},
        "durable_checkout_path_digest": {"$ref": "#/$defs/sha256"},
        "durable_wheel_path_digest": {"$ref": "#/$defs/sha256"}
      }
    },
    "runtime_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instance_id", "runtime_instance_nonce", "expected_process_identity", "claimed_process_identity", "listener_attested_at", "listener_attestation_digest", "request_context_binding_digest", "bind_address", "port", "exposure_profile", "scope_mode", "pilot_root_path_digest", "project_root_path_digest", "ledger_path_digest", "token_file_path_digest", "database_generation", "preflight_receipt_digest", "preflight_observed_at", "preflight_valid_until", "backup_receipt_digest", "backup_sha256", "monotonic_claim_ns", "monotonic_deadline_ns"],
      "properties": {
        "instance_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "runtime_instance_nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]{32,256}$"},
        "expected_process_identity": {"$ref": "#/$defs/sha256"},
        "claimed_process_identity": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]},
        "listener_attested_at": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/date_time"}]},
        "listener_attestation_digest": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]},
        "request_context_binding_digest": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]},
        "bind_address": {"const": "127.0.0.1"},
        "port": {"type": "integer", "minimum": 1024, "maximum": 65535},
        "exposure_profile": {"const": "authoritative_canary"},
        "scope_mode": {"const": "bounded_single_project_pilot.v1"},
        "pilot_root_path_digest": {"$ref": "#/$defs/sha256"},
        "project_root_path_digest": {"$ref": "#/$defs/sha256"},
        "ledger_path_digest": {"$ref": "#/$defs/sha256"},
        "token_file_path_digest": {"$ref": "#/$defs/sha256"},
        "database_generation": {"type": "integer", "minimum": 1},
        "preflight_receipt_digest": {"$ref": "#/$defs/sha256"},
        "preflight_observed_at": {"$ref": "#/$defs/date_time"},
        "preflight_valid_until": {"$ref": "#/$defs/date_time"},
        "backup_receipt_digest": {"$ref": "#/$defs/sha256"},
        "backup_sha256": {"$ref": "#/$defs/sha256"},
        "monotonic_claim_ns": {"oneOf": [{"type": "null"}, {"type": "integer", "minimum": 0}]},
        "monotonic_deadline_ns": {"oneOf": [{"type": "null"}, {"type": "integer", "minimum": 1}]}
      }
    },
    "principal_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principal_id", "principal_kind", "session_ref", "caller_auth_mode", "principal_authenticated_by", "permissions", "combined_operator_reviewer_role_explicitly_authorized"],
      "properties": {
        "principal_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "principal_kind": {"enum": ["human", "service", "agent"]},
        "session_ref": {"type": "string", "minLength": 1, "maxLength": 2048},
        "caller_auth_mode": {"const": "token"},
        "principal_authenticated_by": {"const": "local_session"},
        "permissions": {"type": "array", "minItems": 1, "maxItems": 7, "uniqueItems": true, "items": {"enum": ["work_item.accept", "work_item.approve", "work_item.cancel", "work_item.ready", "work_item.return_for_revision", "work_item.start_delivery", "work_item.submit"]}},
        "combined_operator_reviewer_role_explicitly_authorized": {"type": "boolean"}
      }
    },
    "scope_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "project_snapshot_digest", "proposed_work_item_id", "authorized_work_item_id", "origin_digest", "authorized_create_command_digest", "objective_digest", "task_version_payload_digests", "execution_attempt_slot_schema_sha256", "execution_authorization_receipt_schema_sha256", "execution_authorization_receipt_digest", "artifact_policy_digest", "protected_path_manifest_digest", "allowed_write_path_manifest_digest"],
      "properties": {
        "project_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "project_snapshot_digest": {"$ref": "#/$defs/sha256"},
        "proposed_work_item_id": {"$ref": "#/$defs/work_item_id"},
        "authorized_work_item_id": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/work_item_id"}]},
        "origin_digest": {"$ref": "#/$defs/sha256"},
        "authorized_create_command_digest": {"$ref": "#/$defs/sha256"},
        "objective_digest": {"$ref": "#/$defs/sha256"},
        "task_version_payload_digests": {"type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}},
        "execution_attempt_slot_schema_sha256": {"$ref": "#/$defs/sha256"},
        "execution_authorization_receipt_schema_sha256": {"$ref": "#/$defs/sha256"},
        "execution_authorization_receipt_digest": {"$ref": "#/$defs/sha256"},
        "artifact_policy_digest": {"$ref": "#/$defs/sha256"},
        "protected_path_manifest_digest": {"$ref": "#/$defs/sha256"},
        "allowed_write_path_manifest_digest": {"$ref": "#/$defs/sha256"}
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issued_at", "not_before", "expires_at", "maximum_runtime_seconds", "maximum_preflight_age_seconds"],
      "properties": {
        "issued_at": {"$ref": "#/$defs/date_time"},
        "not_before": {"$ref": "#/$defs/date_time"},
        "expires_at": {"$ref": "#/$defs/date_time"},
        "maximum_runtime_seconds": {"const": 14400},
        "maximum_preflight_age_seconds": {"const": 120}
      }
    },
    "quotas": {"$ref": "#/$defs/quotas"},
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["new_work_items", "task_versions", "runtime_attempts", "attempt_events", "artifacts", "decisions", "applied_gate_events", "rejected_gate_events", "gate_events_total", "audit_events", "outbox_events", "acceptance_manifests", "lease_events", "execution_slots"],
      "properties": {
        "new_work_items": {"type": "integer", "minimum": 0, "maximum": 1},
        "task_versions": {"type": "integer", "minimum": 0, "maximum": 3},
        "runtime_attempts": {"type": "integer", "minimum": 0, "maximum": 4},
        "attempt_events": {"type": "integer", "minimum": 0, "maximum": 8},
        "artifacts": {"type": "integer", "minimum": 0, "maximum": 12},
        "decisions": {"type": "integer", "minimum": 0, "maximum": 8},
        "applied_gate_events": {"type": "integer", "minimum": 0, "maximum": 10},
        "rejected_gate_events": {"type": "integer", "minimum": 0, "maximum": 10},
        "gate_events_total": {"type": "integer", "minimum": 0, "maximum": 20},
        "audit_events": {"type": "integer", "minimum": 0, "maximum": 20},
        "outbox_events": {"type": "integer", "minimum": 0, "maximum": 20},
        "acceptance_manifests": {"type": "integer", "minimum": 0, "maximum": 1},
        "lease_events": {"type": "integer", "minimum": 1, "maximum": 64},
        "execution_slots": {
          "type": "array", "minItems": 1, "maxItems": 4,
          "items": {"$ref": "#/$defs/execution_slot_state"}
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transaction_mode", "atomic_first_work_item_binding", "idempotent_replay_charges_quota", "exact_replay_writes_lease_event", "actual_fact_reconciliation", "unknown_command", "direct_service_bypass", "expiry_without_watchdog"],
      "properties": {
        "transaction_mode": {"const": "BEGIN_IMMEDIATE"},
        "atomic_first_work_item_binding": {"const": true},
        "idempotent_replay_charges_quota": {"const": false},
        "exact_replay_writes_lease_event": {"const": false},
        "actual_fact_reconciliation": {"const": true},
        "unknown_command": {"const": "deny"},
        "direct_service_bypass": {"const": "deny_without_exact_lease_and_request_context"},
        "expiry_without_watchdog": {"const": "fail_closed"}
      }
    },
    "maintenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["restore", "migration", "backup", "delivery", "outbox_dispatch", "stable_promotion", "push"],
      "properties": {
        "restore": {"const": "deny_while_nonterminal"},
        "migration": {"const": "deny_after_prepared"},
        "backup": {"const": "control_plane_only"},
        "delivery": {"const": "deny"},
        "outbox_dispatch": {"const": "deny"},
        "stable_promotion": {"const": "deny"},
        "push": {"const": "deny"}
      }
    },
    "failure_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reject_domain_transaction", "freeze_authoritative_writes", "preserve_append_only_evidence", "restore_shadow_on_closeout", "automatic_retry"],
      "properties": {
        "reject_domain_transaction": {"const": true},
        "freeze_authoritative_writes": {"const": true},
        "preserve_append_only_evidence": {"const": true},
        "restore_shadow_on_closeout": {"const": true},
        "automatic_retry": {"const": false}
      }
    },
    "status": {"enum": ["prepared", "claimed", "active", "closed", "revoked", "expired", "write_frozen"]},
    "state_version": {"type": "integer", "minimum": 1},
    "created_at": {"$ref": "#/$defs/date_time"},
    "updated_at": {"$ref": "#/$defs/date_time"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "active"}}, "required": ["status"]},
      "then": {
        "properties": {
          "runtime_binding": {
            "properties": {
              "claimed_process_identity": {"$ref": "#/$defs/sha256"},
              "listener_attested_at": {"$ref": "#/$defs/date_time"},
              "listener_attestation_digest": {"$ref": "#/$defs/sha256"},
              "request_context_binding_digest": {"$ref": "#/$defs/sha256"},
              "monotonic_claim_ns": {"type": "integer", "minimum": 0},
              "monotonic_deadline_ns": {"type": "integer", "minimum": 1}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"usage": {"properties": {"new_work_items": {"const": 0}}, "required": ["new_work_items"]}}, "required": ["usage"]},
      "then": {"properties": {"scope_binding": {"properties": {"authorized_work_item_id": {"type": "null"}}}}}
    },
    {
      "if": {"properties": {"usage": {"properties": {"new_work_items": {"const": 1}}, "required": ["new_work_items"]}}, "required": ["usage"]},
      "then": {"properties": {"scope_binding": {"properties": {"authorized_work_item_id": {"$ref": "#/$defs/work_item_id"}}}}}
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "git_sha1": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "date_time": {"type": "string", "format": "date-time", "maxLength": 64},
    "lease_id": {"type": "string", "pattern": "^lease_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "work_item_id": {"type": "string", "pattern": "^wi_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "execution_slot_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot_id", "ordinal", "task_version", "task_version_payload_digest", "objective_digest", "retry_of_slot_id", "maximum_attempt_runtime_seconds", "status", "attempt_id", "bound_at", "completed_at"],
      "properties": {
        "slot_id": {"type": "string", "pattern": "^exec_slot_[A-Za-z0-9._-]{8,192}$"},
        "ordinal": {"type": "integer", "minimum": 1, "maximum": 4},
        "task_version": {"type": "integer", "minimum": 1, "maximum": 3},
        "task_version_payload_digest": {"$ref": "#/$defs/sha256"},
        "objective_digest": {"$ref": "#/$defs/sha256"},
        "retry_of_slot_id": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^exec_slot_[A-Za-z0-9._-]{8,192}$"}]},
        "maximum_attempt_runtime_seconds": {"type": "integer", "minimum": 1, "maximum": 14400},
        "status": {"enum": ["available", "bound", "completed", "revoked"]},
        "attempt_id": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^attempt_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"}]},
        "bound_at": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/date_time"}]},
        "completed_at": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/date_time"}]}
      },
      "allOf": [
        {"if": {"properties": {"status": {"enum": ["available", "revoked"]}}, "required": ["status"]}, "then": {"properties": {"attempt_id": {"type": "null"}, "bound_at": {"type": "null"}, "completed_at": {"type": "null"}}}},
        {"if": {"properties": {"status": {"const": "bound"}}, "required": ["status"]}, "then": {"properties": {"attempt_id": {"type": "string"}, "bound_at": {"$ref": "#/$defs/date_time"}, "completed_at": {"type": "null"}}}},
        {"if": {"properties": {"status": {"const": "completed"}}, "required": ["status"]}, "then": {"properties": {"attempt_id": {"type": "string"}, "bound_at": {"$ref": "#/$defs/date_time"}, "completed_at": {"$ref": "#/$defs/date_time"}}}}
      ]
    },
    "quotas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximum_new_work_items", "maximum_task_versions", "maximum_runtime_attempts", "maximum_attempt_events", "maximum_artifacts", "maximum_decisions", "maximum_applied_gate_events", "maximum_rejected_gate_events", "maximum_gate_events_total", "maximum_audit_events", "maximum_outbox_events", "maximum_acceptance_manifests", "maximum_lease_events"],
      "properties": {
        "maximum_new_work_items": {"const": 1},
        "maximum_task_versions": {"const": 3},
        "maximum_runtime_attempts": {"const": 4},
        "maximum_attempt_events": {"const": 8},
        "maximum_artifacts": {"const": 12},
        "maximum_decisions": {"const": 8},
        "maximum_applied_gate_events": {"const": 10},
        "maximum_rejected_gate_events": {"const": 10},
        "maximum_gate_events_total": {"const": 20},
        "maximum_audit_events": {"const": 20},
        "maximum_outbox_events": {"const": 20},
        "maximum_acceptance_manifests": {"const": 1},
        "maximum_lease_events": {"const": 64}
      }
    }
  }
}
