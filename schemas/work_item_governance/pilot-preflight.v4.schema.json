      "type": "object",
      "additionalProperties": false,
      "required": ["public_endpoint", "relay_or_tunnel", "existing_service_modified", "other_project_modified", "push", "stable_promotion", "one_unconsumed_decision_matches"],
      "properties": {
        "public_endpoint": {"const": false},
        "relay_or_tunnel": {"const": false},
        "existing_service_modified": {"const": false},
        "other_project_modified": {"const": false},
        "push": {"const": false},
        "stable_promotion": {"const": false},
        "one_unconsumed_decision_matches": {"const": true}
      }
    }
