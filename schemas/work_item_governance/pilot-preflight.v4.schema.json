    "gate_id": {"type": "string", "minLength": 1, "maxLength": 192},
    "observed_at": {"$ref": "#/$defs/date_time"},
    "valid_until": {"$ref": "#/$defs/date_time"},
    "result": {"const": "PASS"},
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorization_digest", "scope_envelope_digest", "candidate_manifest_sha256", "file_list_root_sha256", "storage_schema_contract_digest", "fact_reconciliation_contract_digest", "semantic_rules_digest", "project_snapshot_digest", "execution_attempt_slot_schema_sha256", "execution_authorization_receipt_schema_sha256", "execution_authorization_receipt_digest", "authentication_conformance_receipt_schema_sha256", "expiry_conformance_receipt_schema_sha256"],
      "properties": {
        "authorization_digest": {"$ref": "#/$defs/sha256"},
        "scope_envelope_digest": {"$ref": "#/$defs/sha256"},
        "candidate_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "file_list_root_sha256": {"$ref": "#/$defs/sha256"},
        "storage_schema_contract_digest": {"$ref": "#/$defs/sha256"},
        "fact_reconciliation_contract_digest": {"$ref": "#/$defs/sha256"},
        "semantic_rules_digest": {"$ref": "#/$defs/sha256"},
        "project_snapshot_digest": {"$ref": "#/$defs/sha256"},
        "execution_attempt_slot_schema_sha256": {"$ref": "#/$defs/sha256"},
        "execution_authorization_receipt_schema_sha256": {"$ref": "#/$defs/sha256"},
        "execution_authorization_receipt_digest": {"$ref": "#/$defs/sha256"}
        ,"authentication_conformance_receipt_schema_sha256": {"$ref": "#/$defs/sha256"}
        ,"expiry_conformance_receipt_schema_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "execution_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation_commit", "implementation_tree", "wheel_sha256", "installed_inventory_sha256", "python_executable", "cwd", "runtime_binding_digest"],
      "properties": {
        "implementation_commit": {"$ref": "#/$defs/git_sha1"},
        "implementation_tree": {"$ref": "#/$defs/git_sha1"},
        "wheel_sha256": {"$ref": "#/$defs/sha256"},
