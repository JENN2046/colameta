{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colameta.local/schemas/wig-p3-bounded-single-project-pilot-preflight.v4.schema.json",
  "title": "Bounded Single-Project Pilot Preflight Receipt v4",
