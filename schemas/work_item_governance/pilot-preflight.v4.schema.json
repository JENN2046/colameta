        "caller_auth_mode": {"const": "token"},
        "principal_authenticated_by": {"const": "local_session"},
        "token_file_mode": {"const": "0600"},
        "token_parent_mode": {"enum": ["0700", "stricter_than_0700"]},
        "token_owner_matches_runtime_user": {"const": true},
        "token_format_valid": {"const": true},
        "token_ledger_binding_valid": {"const": true},
        "token_absent_from_cmdline": {"const": true},
        "token_absent_from_environment": {"const": true},
        "token_absent_from_bundle": {"const": true},
        "token_absent_from_logs": {"const": true},
        "authentication_conformance_receipt_digest": {"$ref": "#/$defs/sha256"},
        "principal_binding_digest": {"$ref": "#/$defs/sha256"}
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exposure_profile", "scope_mode", "visible_tool_count", "visible_tool_set_digest", "definitions_dispatch_exact_match", "resources_disabled_or_empty", "actions_disabled", "hidden_tool_rejected", "alternate_dispatch_rejected", "prohibited_workers_running"],
      "properties": {
        "exposure_profile": {"const": "authoritative_canary"},
        "scope_mode": {"const": "bounded_single_project_pilot.v1"},
        "visible_tool_count": {"const": 14},
        "visible_tool_set_digest": {"$ref": "#/$defs/sha256"},
        "definitions_dispatch_exact_match": {"const": true},
        "resources_disabled_or_empty": {"const": true},
        "actions_disabled": {"const": true},
        "hidden_tool_rejected": {"const": true},
        "alternate_dispatch_rejected": {"const": true},
        "prohibited_workers_running": {"const": false}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bind_address", "port", "listener_before_activation", "port_available", "gate_mode", "authoritative"],
      "properties": {
        "bind_address": {"const": "127.0.0.1"},
        "port": {"type": "integer", "minimum": 1024, "maximum": 65535},
        "listener_before_activation": {"const": false},
        "port_available": {"const": true},
        "gate_mode": {"const": "shadow"},
        "authoritative": {"const": false}
      }
    },
    "semantic_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rules_digest", "receipt_digest", "rules_evaluated", "rules_failed", "result"],
      "properties": {
        "rules_digest": {"$ref": "#/$defs/sha256"},
        "receipt_digest": {"$ref": "#/$defs/sha256"},
        "rules_evaluated": {"type": "integer", "minimum": 1},
        "rules_failed": {"const": 0},
        "result": {"const": "PASS"}
      }
