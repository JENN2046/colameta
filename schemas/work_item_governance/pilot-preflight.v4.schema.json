        "xdg_cache_home": {"$ref": "#/$defs/absolute_path"},
        "xdg_data_home": {"$ref": "#/$defs/absolute_path"},
        "registry_path": {"$ref": "#/$defs/absolute_path"},
        "token_file_path": {"$ref": "#/$defs/absolute_path"},
