  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "git_sha1": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "date_time": {"type": "string", "format": "date-time", "maxLength": 64},
    "absolute_path": {"type": "string", "pattern": "^/", "minLength": 2, "maxLength": 4096},
    "zero_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["work_items", "task_versions", "execution_attempts", "attempt_events", "artifact_refs", "decision_records", "gate_events", "acceptance_manifests", "activation_leases", "activation_lease_events", "pilot_activation_leases", "pilot_activation_lease_events", "external_associations", "delivery_receipts", "blocker_events", "audit_events", "outbox_events", "inbox_events"],
      "properties": {
        "work_items": {"const": 0}, "task_versions": {"const": 0}, "execution_attempts": {"const": 0}, "attempt_events": {"const": 0}, "artifact_refs": {"const": 0}, "decision_records": {"const": 0}, "gate_events": {"const": 0}, "acceptance_manifests": {"const": 0}, "activation_leases": {"const": 0}, "activation_lease_events": {"const": 0}, "pilot_activation_leases": {"const": 0}, "pilot_activation_lease_events": {"const": 0}, "external_associations": {"const": 0}, "delivery_receipts": {"const": 0}, "blocker_events": {"const": 0}, "audit_events": {"const": 0}, "outbox_events": {"const": 0}, "inbox_events": {"const": 0}
      }
    }
  }
}
