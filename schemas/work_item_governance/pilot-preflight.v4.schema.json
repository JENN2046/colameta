      "required": ["path", "path_digest", "schema_version", "database_generation", "storage_migration_receipt_digest", "legacy_table_digests_unchanged", "integrity_check", "foreign_key_violations", "zero_fact_baseline", "preview_signing_key_preprovisioned"],
