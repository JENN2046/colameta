{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colameta.local/schemas/wig-p3-bounded-single-project-pilot-authorization.v4.schema.json",
  "title": "Bounded Single-Project Pilot One-Shot Authorization v4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "gate_id", "decision", "source", "bindings", "target", "principal", "window", "one_shot", "authority"],
  "properties": {
    "schema_version": {"const": "wig_p3_bounded_single_project_pilot_authorization.v4"},
    "gate_id": {"type": "string", "pattern": "^WIG-P3-AUTHORITATIVE-SINGLE-PROJECT-PILOT-[A-Z0-9-]+$", "maxLength": 192},
    "decision": {"const": "AUTHORIZED"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation_commit", "implementation_tree", "wheel_sha256", "installed_inventory_sha256"],
      "properties": {
        "implementation_commit": {"$ref": "#/$defs/git_sha1"},
        "implementation_tree": {"$ref": "#/$defs/git_sha1"},
        "wheel_sha256": {"$ref": "#/$defs/sha256"},
        "installed_inventory_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remediated_spec_manifest_sha256", "candidate_manifest_sha256", "file_list_root_sha256", "scope_envelope_sha256", "authorized_scope_digest", "scope_schema_sha256", "storage_schema_contract_sha256", "activation_lease_schema_sha256", "lease_event_schema_sha256", "fact_reconciliation_contract_sha256", "semantic_rules_sha256", "semantic_validation_receipt_schema_sha256", "execution_attempt_slot_schema_sha256", "execution_authorization_receipt_schema_sha256", "authentication_conformance_receipt_schema_sha256", "authentication_conformance_receipt_digest", "expiry_conformance_receipt_schema_sha256", "tool_allowlist_sha256", "write_matrix_sha256", "write_path_inventory_sha256", "preflight_schema_sha256", "closeout_schema_sha256", "negative_test_matrix_sha256", "project_snapshot_digest", "execution_authorization_receipt_digest"],
      "properties": {
        "remediated_spec_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "file_list_root_sha256": {"$ref": "#/$defs/sha256"},
        "scope_envelope_sha256": {"$ref": "#/$defs/sha256"},
        "authorized_scope_digest": {"$ref": "#/$defs/sha256"},
        "scope_schema_sha256": {"$ref": "#/$defs/sha256"},
        "storage_schema_contract_sha256": {"$ref": "#/$defs/sha256"},
        "activation_lease_schema_sha256": {"$ref": "#/$defs/sha256"},
        "lease_event_schema_sha256": {"$ref": "#/$defs/sha256"},
        "fact_reconciliation_contract_sha256": {"$ref": "#/$defs/sha256"},
        "semantic_rules_sha256": {"$ref": "#/$defs/sha256"},
        "semantic_validation_receipt_schema_sha256": {"$ref": "#/$defs/sha256"},
        "execution_attempt_slot_schema_sha256": {"$ref": "#/$defs/sha256"},
        "execution_authorization_receipt_schema_sha256": {"$ref": "#/$defs/sha256"},
        "authentication_conformance_receipt_schema_sha256": {"$ref": "#/$defs/sha256"},
        "authentication_conformance_receipt_digest": {"$ref": "#/$defs/sha256"},
        "expiry_conformance_receipt_schema_sha256": {"$ref": "#/$defs/sha256"},
        "tool_allowlist_sha256": {"$ref": "#/$defs/sha256"},
        "write_matrix_sha256": {"$ref": "#/$defs/sha256"},
        "write_path_inventory_sha256": {"$ref": "#/$defs/sha256"},
        "preflight_schema_sha256": {"$ref": "#/$defs/sha256"},
        "closeout_schema_sha256": {"$ref": "#/$defs/sha256"},
        "negative_test_matrix_sha256": {"$ref": "#/$defs/sha256"},
        "project_snapshot_digest": {"$ref": "#/$defs/sha256"},
        "execution_authorization_receipt_digest": {"$ref": "#/$defs/sha256"}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "project_root_path_digest", "pilot_root_path_digest", "ledger_schema_version", "bind_address", "port", "exposure_profile", "scope_mode"],
      "properties": {
        "project_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "project_root_path_digest": {"$ref": "#/$defs/sha256"},
        "pilot_root_path_digest": {"$ref": "#/$defs/sha256"},
        "ledger_schema_version": {"const": 7},
        "bind_address": {"const": "127.0.0.1"},
        "port": {"type": "integer", "minimum": 1024, "maximum": 65535},
        "exposure_profile": {"const": "authoritative_canary"},
        "scope_mode": {"const": "bounded_single_project_pilot.v1"}
      }
    },
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principal_id", "principal_kind", "session_ref", "caller_auth_mode", "authenticated_by", "permissions", "combined_operator_reviewer_role_explicitly_authorized"],
      "properties": {
        "principal_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "principal_kind": {"enum": ["human", "service", "agent"]},
        "session_ref": {"type": "string", "minLength": 1, "maxLength": 2048},
        "caller_auth_mode": {"const": "token"},
        "authenticated_by": {"const": "local_session"},
        "permissions": {"type": "array", "minItems": 1, "maxItems": 7, "uniqueItems": true, "items": {"enum": ["work_item.accept", "work_item.approve", "work_item.cancel", "work_item.ready", "work_item.return_for_revision", "work_item.start_delivery", "work_item.submit"]}},
        "combined_operator_reviewer_role_explicitly_authorized": {"type": "boolean"}
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issued_at", "not_before", "expires_at", "maximum_runtime_seconds", "maximum_preflight_age_seconds"],
      "properties": {
        "issued_at": {"$ref": "#/$defs/date_time"},
        "not_before": {"$ref": "#/$defs/date_time"},
        "expires_at": {"$ref": "#/$defs/date_time"},
        "maximum_runtime_seconds": {"const": 14400},
        "maximum_preflight_age_seconds": {"const": 120}
      }
    },
    "one_shot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_may_be_consumed", "permanent_tombstone_required", "retry_after_consumption", "retry_after_runtime_failure"],
      "properties": {
        "decision_may_be_consumed": {"const": 1},
        "permanent_tombstone_required": {"const": true},
        "retry_after_consumption": {"const": false},
        "retry_after_runtime_failure": {"const": false}
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activate_exact_pilot_once", "real_work_item", "external_execution", "push", "stable_promotion", "existing_service_replacement", "public_endpoint", "relay_or_tunnel"],
      "properties": {
        "activate_exact_pilot_once": {"const": true},
        "real_work_item": {"const": true},
        "external_execution": {"const": true},
        "push": {"const": false},
        "stable_promotion": {"const": false},
        "existing_service_replacement": {"const": false},
        "public_endpoint": {"const": false},
        "relay_or_tunnel": {"const": false}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "git_sha1": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "date_time": {"type": "string", "format": "date-time", "maxLength": 64}
  }
}
