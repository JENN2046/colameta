{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colameta.local/schemas/work-item-governance/execution-envelope.v2.schema.json",
  "title": "ColaMeta Execution Envelope v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "envelope_id", "envelope_schema_version", "version_taskbook_ref", "master_taskbook_ref",
    "stage_taskbook_ref", "authority_mode", "local_execution_authorization_ref",
    "imported_receipt_authorization_ref", "allowed_files", "forbidden_files", "allowed_commands",
    "validation_commands", "timeout_limits", "network_policy", "secrets_policy",
    "destructive_operation_policy", "retry_policy", "stop_conditions", "work_item_id",
    "task_version", "attempt_id", "objective_ref", "artifact_contract", "approval_requirements",
    "reporting_destination", "expected_receipt_contract"
  ],
  "properties": {
    "envelope_id": {"type": "string", "minLength": 1, "maxLength": 1024},
    "envelope_schema_version": {"const": "execution_envelope.v2"},
    "version_taskbook_ref": {"$ref": "#/$defs/taskbookRef"},
    "master_taskbook_ref": {"$ref": "#/$defs/taskbookRef"},
    "stage_taskbook_ref": {"$ref": "#/$defs/taskbookRef"},
    "authority_mode": {"enum": ["local_execution", "imported_receipt", "validation_only"]},
    "local_execution_authorization_ref": {"type": "object"},
    "imported_receipt_authorization_ref": {"type": "object"},
    "allowed_files": {"$ref": "#/$defs/nonEmptyStringList"},
    "forbidden_files": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "allowed_commands": {"$ref": "#/$defs/nonEmptyStringList"},
    "validation_commands": {"$ref": "#/$defs/nonEmptyStringList"},
    "timeout_limits": {"type": "object", "minProperties": 1},
    "network_policy": {"type": "object", "minProperties": 1},
    "secrets_policy": {"type": "object", "minProperties": 1},
    "destructive_operation_policy": {"type": "object", "minProperties": 1},
    "retry_policy": {"type": "object", "minProperties": 1},
    "stop_conditions": {"$ref": "#/$defs/nonEmptyStringList"},
    "work_item_id": {
      "anyOf": [{"$ref": "definitions.v1.schema.json#/$defs/workItemId"}, {"type": "null"}]
    },
    "task_version": {
      "anyOf": [{"$ref": "definitions.v1.schema.json#/$defs/taskVersion"}, {"type": "null"}]
    },
    "attempt_id": {
      "anyOf": [{"$ref": "definitions.v1.schema.json#/$defs/attemptId"}, {"type": "null"}]
    },
    "objective_ref": {"type": ["string", "null"], "maxLength": 8192},
    "artifact_contract": {"type": "object"},
    "approval_requirements": {"type": "object"},
    "reporting_destination": {"type": "object"},
    "expected_receipt_contract": {"type": "object"}
  },
  "oneOf": [
    {
      "properties": {
        "work_item_id": {"type": "null"},
        "task_version": {"type": "null"},
        "attempt_id": {"type": "null"},
        "objective_ref": {"type": "null"}
      }
    },
    {
      "properties": {
        "work_item_id": {"$ref": "definitions.v1.schema.json#/$defs/workItemId"},
        "task_version": {"$ref": "definitions.v1.schema.json#/$defs/taskVersion"},
        "attempt_id": {"$ref": "definitions.v1.schema.json#/$defs/attemptId"},
        "objective_ref": {"type": "string", "minLength": 1, "maxLength": 8192}
      }
    }
  ],
  "$defs": {
    "taskbookRef": {
      "type": "object",
      "required": ["path", "raw_snapshot_sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 4096},
        "raw_snapshot_sha256": {"$ref": "definitions.v1.schema.json#/$defs/sha256"}
      },
      "additionalProperties": true
    },
    "nonEmptyStringList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
