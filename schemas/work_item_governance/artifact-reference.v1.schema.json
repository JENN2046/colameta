{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colameta.local/schemas/work-item-governance/artifact-reference.v1.schema.json",
  "title": "ColaMeta Artifact Reference v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_id", "work_item_id", "task_version", "attempt_id",
    "kind", "uri", "immutable_ref", "digest", "metadata", "created_at"
  ],
  "properties": {
    "schema_version": {"const": "artifact_reference.v1"},
    "artifact_id": {"$ref": "definitions.v1.schema.json#/$defs/artifactId"},
    "work_item_id": {"$ref": "definitions.v1.schema.json#/$defs/workItemId"},
    "task_version": {"$ref": "definitions.v1.schema.json#/$defs/taskVersion"},
    "attempt_id": {
      "anyOf": [{"$ref": "definitions.v1.schema.json#/$defs/attemptId"}, {"type": "null"}]
    },
    "kind": {"enum": ["report", "validation", "git_commit", "git_diff", "file", "test_report", "evidence_receipt", "other"]},
    "uri": {"type": "string", "minLength": 1, "maxLength": 8192},
    "immutable_ref": {"type": "string", "minLength": 1, "maxLength": 8192},
    "digest": {"$ref": "definitions.v1.schema.json#/$defs/sha256"},
    "metadata": {"$ref": "definitions.v1.schema.json#/$defs/metadata"},
    "source_event_key": {"type": ["string", "null"], "maxLength": 1024},
    "created_at": {"$ref": "definitions.v1.schema.json#/$defs/timestamp"}
  }
}
