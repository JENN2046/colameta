{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colameta.local/schemas/work-item-governance/definitions.v1.schema.json",
  "title": "ColaMeta Work Item Governance shared definitions v1",
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64
    },
    "workItemId": {
      "type": "string",
      "pattern": "^wi_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "attemptId": {
      "type": "string",
      "pattern": "^attempt_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "artifactId": {
      "type": "string",
      "pattern": "^artifact_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "decisionId": {
      "type": "string",
      "pattern": "^decision_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "gateEventId": {
      "type": "string",
      "pattern": "^gate_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "deliveryReceiptId": {
      "type": "string",
      "pattern": "^delivery_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "acceptanceManifestId": {
      "type": "string",
      "pattern": "^acceptance_manifest_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "taskVersion": {
      "type": "integer",
      "minimum": 1
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref", "snapshot_digest"],
      "properties": {
        "kind": {
          "enum": ["quick_chat", "project", "workbench", "slack", "linear", "manual", "imported"]
        },
        "ref": {
          "type": ["string", "null"],
          "maxLength": 2048
        },
        "snapshot_digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 512},
        "kind": {"type": "string", "minLength": 1, "maxLength": 128},
        "display_name": {"type": ["string", "null"], "maxLength": 512}
      }
    },
    "authorityBasis": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 32,
      "additionalProperties": true
    },
    "principalContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id", "principal_kind", "authenticated_by",
        "granted_permissions", "session_ref"
      ],
      "properties": {
        "principal_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "principal_kind": {"enum": ["human", "service", "agent"]},
        "authenticated_by": {"enum": ["local_session", "oauth", "commander"]},
        "granted_permissions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "work_item.ready", "work_item.start_delivery", "work_item.submit",
              "work_item.accept", "work_item.cancel", "work_item.return_for_revision",
              "work_item.approve"
            ]
          }
        },
        "session_ref": {"type": ["string", "null"], "maxLength": 2048}
      }
    },
    "metadata": {
      "type": "object",
      "maxProperties": 128,
      "additionalProperties": true
    }
  }
}
